# MySQL connection string used by Drizzle and server-side database access.
DATABASE_URL="mysql://user:password@localhost:3306/autodox"

# Secret used to encrypt Nuxt session cookies. Use a long random value in production.
NUXT_SESSION_PASSWORD="change-me-to-a-long-random-secret"

# Shared secret for protecting Puppeteer-related endpoints or jobs.
PUPPETEER_SECRET="change-me"

# Google OAuth client ID from the Google Cloud Console.
NUXT_OAUTH_GOOGLE_CLIENT_ID=""

# Google OAuth client secret from the Google Cloud Console.
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=""

# Runtime environment. Use "development" locally and "production" in production.
NODE_ENV="development"

# Host interface for the Nuxt server.
NUXT_HOST="0.0.0.0"

# Port for the Nuxt server.
NUXT_PORT="3000"

# Directory where uploaded files are stored.
UPLOAD_DIR="./uploads"
